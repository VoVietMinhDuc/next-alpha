# Copy to .env and fill in real values. NEVER commit the real .env.
# Generic key name so it works for OpenAI or Gemini (per the brief).
API_KEY=

# Reuse the same Gemini File Search Store across daily runs. Leave blank on the
# first run; the uploader logs a new name (FILE_SEARCH_STORE_NAME=...) to paste back here.
FILE_SEARCH_STORE_NAME=

# Optional overrides
ZENDESK_BASE_URL=https://support.optisigns.com/api/v2/help_center
LOG_LEVEL=INFO

# Max articles to scrape per run (brief requires >= 30). 0 = no cap (all articles).
MAX_ARTICLES=40
