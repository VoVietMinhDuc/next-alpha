# Copy to .env and fill in real values. NEVER commit the real .env.
# Generic key name so it works for OpenAI or Gemini (per the brief).
API_KEY=

# Reuse the same vector store across daily runs. Leave blank on first run;
# the uploader prints a new id to paste back here.
VECTOR_STORE_ID=

# Optional overrides
ZENDESK_BASE_URL=https://support.optisigns.com/api/v2/help_center
MIN_ARTICLES=30
